# =============================================================================
# NouPro — Frontend (Expo) environment variables
# =============================================================================
# Copy this file to `.env` and fill in values for your environment.
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the app at runtime.
# Restart the Expo dev server after changing these.

# App environment: dev | demo | prod  (selects API base + behavior)
EXPO_PUBLIC_APP_ENV=dev

# Backend REST base URL. MUST end in /api.
#  - Local dev on a device/simulator: use your machine's LAN IP, not localhost.
#    e.g. http://192.168.1.100:3000/api
#  - Hosted backend: https://nouproapp.onrender.com/api
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api

# Socket.IO base URL (real-time chat). Usually the API URL WITHOUT the /api suffix.
#  - Local dev: http://192.168.1.100:3000
#  - Hosted:    https://nouproapp.onrender.com
# If unset, the app derives it from EXPO_PUBLIC_API_URL.
EXPO_PUBLIC_SOCKET_URL=http://192.168.1.100:3000

# Sentry DSN for frontend crash/error reporting (optional).
# Leave blank to disable. Create a React Native project in Sentry to get a DSN.
EXPO_PUBLIC_SENTRY_DSN=
