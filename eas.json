{
  "cli": {
    "version": ">= 0.46.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "demo",
        "EXPO_PUBLIC_API_URL": "http://192.168.100.226:3000/api"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "prod"
      },
      "ios": {
        "releaseChannel": "production",
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "aab"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6744329387",
        "appleId": "arnaud.labonne@icloud.com",
        "appleTeamId": "M944QKNR68"
      }
    }
  }
} 