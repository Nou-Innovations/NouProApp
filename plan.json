            {
              "id": "1_1_j",
              "name": "Create Subscription types",
              "status": "not_started",
              "details": {
                "plans": ["free", "pro", "business", "enterprise"],
                "prices": { "free": 0, "pro": 799, "business": 1999, "enterprise": 3999 },
                "currency": "MUR"
