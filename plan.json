  "criticalFlowsValidation": {
    "description": "After all phases, validate these critical flows from app-logic.json work correctly",
    "flows": [
      {
        "name": "Distributor: Product to Delivery",
        "steps": [
          "Switch to Business Profile",
          "Products → Add Product → fill details → Save",
          "Stock → select product → add stock quantity",
          "Customer places order OR distributor creates manually",
          "Orders → view incoming order → Accept",
          "Deliveries → assign staff → update status until Delivered"
        ]
      },
      {
        "name": "Retailer Orders from Distributor",
        "steps": [
          "Switch to Retailer's Business Profile",
          "Go to Explore/search",
          "Open Distributor Public Business Page",
          "Browse Products → add items to Cart",
          "Go to Cart → confirm → submit Order Request",
          "Order appears in Distributor's Orders tab"
        ]
      },
      {
        "name": "Staff Delivery Flow",
        "steps": [
          "Log in → Personal Profile Home",
          "Switch to assigned Business Profile",
          "Only Deliveries tab visible",
          "Open Delivery List → tap assigned delivery",
          "Update status: Pending → On the way → Delivered",
          "Optionally add note/photo as proof"
        ]
      },
      {
        "name": "Business Setup & Publish",
        "steps": [
          "From Personal Profile → Create Business Profile",
          "Enter company info",
          "Switch into new Business Profile",
          "Go to Business tab → Public Profile section",
          "Toggle Publish Profile ON",
          "Select which products are public",
          "Save & preview"
        ]
      }
    ]
  },

