{
  "$schema": "https://noupro.app/plan/v1",
  "version": "1.0.0",
  "name": "NouPro App Architecture Migration Plan",
  "description": "Complete implementation plan to align the NouPro app with app-logic.json specification. This plan establishes the dual-mode identity system, proper navigation, and all business features.",
  "createdAt": "2025-12-12",
  "lastUpdated": "2025-12-12",
  "status": "in_progress",

  "summary": {
    "totalPhases": 5,
    "estimatedDuration": "6 weeks",
    "criticalPath": ["phase1", "phase2", "phase3"],
    "currentPhase": "phase3"
  },

  "phases": {
    "phase1": {
      "name": "Foundation - Core Architecture",
      "description": "Establish the dual-mode identity system, update type definitions, and refactor navigation to support Personal and Business modes",
      "priority": "critical",
      "estimatedDuration": "1-2 weeks",
      "status": "completed",
      "completedAt": "2025-12-12",
      "blockedBy": [],
      
      "tasks": {
        "task1_1": {
          "name": "Update Type Definitions",
          "description": "Align all TypeScript types with app-logic.json data models",
          "status": "not_started",
          "priority": "critical",
          "estimatedHours": 4,
          "files": [
            "src/types/user.ts",
            "src/types/business.ts",
            "src/types/product.ts",
            "src/types/order.ts",
            "src/types/roles.ts",
            "src/types/subscription.ts",
            "src/types/store.ts"
          ],
          "subtasks": [
            {
              "id": "1_1_a",
              "name": "Create User type matching app-logic userProfile",
              "status": "not_started",
              "details": {
                "fields": ["id (UUID)", "name", "email (optional)", "phone (optional)", "password_hash", "language (EN/FR)", "notifications_on", "created_at"],
                "notes": "User Profile is personal identity, REQUIRED for everyone"
              }
            },
            {
              "id": "1_1_b",
              "name": "Create Business type matching app-logic businessProfile",
              "status": "not_started",
              "details": {
                "fields": ["id", "owner_id (FK User)", "name", "industry", "description", "logo_url", "banner_url", "plan", "is_published", "subscription_status", "next_billing_date", "created_at"],
                "notes": "Business Profile is professional entity"
              }
            },
            {
              "id": "1_1_c",
              "name": "Create BusinessStaff type",
              "status": "not_started",
              "details": {
                "fields": ["id", "business_id (FK)", "user_id (FK)", "role (staff/admin/super_admin)", "status (pending/accepted/rejected/locked)", "created_at"]
              }
            },
            {
              "id": "1_1_d",
              "name": "Create Brand type",
              "status": "not_started",
              "details": {
                "fields": ["id", "business_id (FK)", "name", "logo_url", "description", "created_at", "updated_at"]
              }
            },
            {
              "id": "1_1_e",
              "name": "Update Product type",
              "status": "not_started",
