            {
              "id": "1_1_g",
              "name": "Create Delivery type",
              "status": "not_started",
              "details": {
                "fields": ["id", "order_id (FK)", "assigned_to (FK User)", "status", "created_at"],
                "statusEnum": ["pending", "on_the_way", "done"]
