generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String           @id
  name                 String?
  email                String?          @unique
  avatar               String?
  phone                String?          @unique
  passwordHash         String?
  twoFactorSecret      String?
  twoFactorEnabled     Boolean          @default(false)
  twoFactorBackupCodes String?
  jobTitle             String?
  description          String?
  address              String?
  language             String?          @default("EN")
  privacySettings      Json?
  lastLoginAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  businessMembers      BusinessMember[]
  locationMembers      LocationMember[]
  sentConnections      UserConnection[] @relation("ConnectionSender")
  receivedConnections  UserConnection[] @relation("ConnectionReceiver")
  deviceTokens         DeviceToken[]
}

model Business {
  id               String            @id
  name             String
  logoUrl          String?
  bannerUrl        String?
  description      String?
  industry         String?
  phone            String?
  email            String?
  address          String?
  website          String?
  isPublished      Boolean           @default(false)
  subscriptionTier SubscriptionTier  @default(FREE)
  billingPeriod    BillingPeriod     @default(MONTHLY)
  currentPeriodEnd DateTime?
  settings         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  businessMembers  BusinessMember[]
  chats            Chat[]
  deliveries       Delivery[]
  feedPosts        FeedPost[]
  invoices         Invoice[]
  locations        Location[]
  locationMembers  LocationMember[]
  locationProducts LocationProduct[]
  orders           Order[]
  products         Product[]
  stocks           Stock[]
  brands           Brand[]
  connectionsSent     BusinessConnection[] @relation("ConnectionsRequested")
  connectionsReceived BusinessConnection[] @relation("ConnectionsReceived")
}

model Location {
  id               String            @id
  businessId       String
  name             String
  address          String?
  phone            String?
  email            String?
  latitude         Float?
  longitude        Float?
  operatingMode    LocationMode      @default(DEPENDENT)
  isPublic         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  chats            Chat[]
  deliveries       Delivery[]
  invoices         Invoice[]
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locationMembers  LocationMember[]
  locationProducts LocationProduct[]
  ordersFulfill    Order[]           @relation("OrdersFulfilledByLocation")
  ordersSold       Order[]           @relation("OrdersSoldByLocation")
  stocks           Stock[]

  @@index([businessId])
}

model Brand {
  id          String    @id
  businessId  String
  name        String
  logoUrl     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

model Product {
  id               String            @id
  businessId       String
  name             String
  brand            String?
  brandLogo        String?
  brandId          String?
  productPicture   String?
  price            Float?
  category         String?
  status           String?
  variants         Json?
  unit             String?
  stockQuantity    Int?
  isListed         Boolean?          @map("is_listed")
  isCreatedByUser  Boolean?
  isDisplayable    Boolean?
  isImported       Boolean?
  description      String?
  costPrice        Float?
  salePrice        Float?
  sku              String?
  barcode          String?
  taxRate          Float?
  supplier         String?
  hasCarton        Boolean?          @default(false)
  unitsPerCarton   Int?
  pricePerCarton   Float?
  hasRetailPriceLimit Boolean?       @default(false)
  retailPriceLimit Float?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  locationProducts LocationProduct[]
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  brandRef         Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  stocks           Stock[]

  @@index([businessId])
  @@index([brandId])
}

model LocationProduct {
  id            String   @id
  businessId    String
  locationId    String
  productId     String
  priceOverride Float?
  taxOverride   Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([businessId])
}

model Stock {
  id         String   @id
  businessId String
  locationId String
  productId  String
  qtyOnHand  Int      @default(0)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([businessId])
}

model Order {
  id                    String          @id
  businessId            String
  soldByScope           OrderScope      @default(PARENT)
  soldByLocationId      String?
  fulfillmentLocationId String?
  customerId            String?
  customerName          String?
  customerAddress       String?
  customerPhone         String?
  buyerBusinessId       String?
  buyerBusinessName     String?
  createdBy             String?
  items                 Json
  totalAmount           Float?
  status                OrderStatus     @default(NEW)
  paymentStatus         PaymentStatus?  @default(UNPAID)
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deliveryStatus        DeliveryStatus? @default(NOT_ASSIGNED)
  statusChangedAt       DateTime?
  statusChangedBy       String?
  statusReason          String?
  lastActivityAt        DateTime?
  business              Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fulfillmentLocation   Location?       @relation("OrdersFulfilledByLocation", fields: [fulfillmentLocationId], references: [id])
  soldByLocation        Location?       @relation("OrdersSoldByLocation", fields: [soldByLocationId], references: [id])
  statusHistory         OrderStatusHistory[]
  deliveries            Delivery[]

  @@index([businessId])
  @@index([soldByLocationId])
  @@index([fulfillmentLocationId])
  @@index([buyerBusinessId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  from      OrderStatus
  to        OrderStatus
  reason    String?
  changedBy String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Invoice {
  id                 String         @id
  businessId         String
  issuedByScope      InvoiceScope   @default(PARENT)
  issuedByLocationId String?
  orderId            String?
  invoiceNumber      String?
  clientName         String?
  clientEmail        String?
  clientPhone        String?
  clientAddress      String?
  amount             Float?
  taxAmount          Float?
  totalAmount        Float?
  paidAmount         Float?         @default(0)
  discount           Float?         @default(0)
  shipping           Float?         @default(0)
  currency           String?        @default("EUR")
  type               String?
  issueDate          DateTime?
  dueDate            DateTime?
  items              Json
  notes              String?
  terms              String?
  referenceNumber    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  status             InvoiceStatus? @default(DRAFT)
  business           Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location           Location?      @relation(fields: [issuedByLocationId], references: [id])

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([issuedByLocationId])
  @@index([status])
  @@index([createdAt])
}

model Chat {
  id               String            @id
  companyId        String?           @map("businessId")
  locationId       String?
  type             String?
  name             String?
  participants     Json?
  lastMessage      Json?
  unreadCount      Int               @default(0)
  avatar           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  business         Business?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location         Location?         @relation(fields: [locationId], references: [id])
  messages         Message[]
  chatParticipants ChatParticipant[]
  readReceipts     ReadReceipt[]

  @@index([companyId])
  @@index([locationId])
}

model Message {
  id           String        @id
  chatId       String
  senderId     String?
  senderName   String?
  content      String?
  type         String?
  timestamp    DateTime      @default(now())
  meta         Json?
  status       String?
  isRead       Boolean       @default(false)
  isOutgoing   Boolean       @default(false)
  chat         Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  readReceipts ReadReceipt[]

  @@index([chatId])
  @@index([chatId, timestamp])
}

model ChatParticipant {
  id          String   @id @default(uuid())
  chatId      String
  userId      String
  joinedAt    DateTime @default(now())
  unreadCount Int      @default(0)
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@index([chatId])
}

model ReadReceipt {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  messageId String
  readAt    DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
  @@index([messageId])
}

model BusinessMember {
  id         String       @id
  businessId String
  userId     String
  role       MemberRole
  status     MemberStatus @default(pending)
  createdAt  DateTime     @default(now())
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
}

model LocationMember {
  id          String       @id
  locationId  String
  businessId  String
  userId      String
  role        MemberRole
  status      MemberStatus @default(pending)
  permissions Json?
  createdAt   DateTime     @default(now())
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location    Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([locationId, userId])
  @@index([locationId])
  @@index([businessId])
}

model Delivery {
  id                       String          @id
  businessId               String
  locationId               String?
  direction                DeliveryDirection?
  type                     DeliveryType?
  clientId                 String?
  clientCompanyLogo        String?
  clientCompanyName        String?
  clientAddress            String?
  clientEmail              String?
  clientPhone              String?
  clientNotes              String?
  distributorName          String?
  distributorNotes         String?
  fromLocation             String?
  toLocation               String?
  orderTime                DateTime?
  expectedDeliveryDateTime DateTime?
  itemCount                Int?
  items                    Json?
  totalAmount              Float?
  trackingNumber           String?
  assignedStaffId          String?
  assignedTo               String?
  transportMode            String?
  orderId                  String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  deliveryStatus           DeliveryStatus? @default(NOT_ASSIGNED)
  paymentStatus            PaymentStatus?  @default(UNPAID)
  business                 Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location                 Location?       @relation(fields: [locationId], references: [id])
  order                    Order?          @relation(fields: [orderId], references: [id])

  @@index([businessId])
  @@index([locationId])
  @@index([orderId])
}

model FeedPost {
  id         String    @id
  businessId String?
  type       String
  timestamp  String?
  data       Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([type])
}

model NotificationRead {
  id              String   @id
  userId          String
  notificationKey String
  readAt          DateTime @default(now())

  @@unique([userId, notificationKey])
  @@index([userId])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}

model NotificationPreference {
  id         String   @id @default(uuid())
  userId     String   @unique
  messages   Boolean  @default(true)
  deliveries Boolean  @default(true)
  invoices   Boolean  @default(true)
  orders     Boolean  @default(true)
  team       Boolean  @default(true)
  system     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum SubscriptionTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum LocationMode {
  DEPENDENT
  INDEPENDENT
}

enum MemberRole {
  super_admin
  admin
  staff
}

enum MemberStatus {
  pending
  accepted
  rejected
  locked
}

enum OrderStatus {
  NEW
  ACCEPTED
  ONGOING
  PENDING
  IN_REVIEW
  DONE
  CANCELED
  REJECTED
}

enum OrderScope {
  PARENT
  LOCATION
}

enum InvoiceScope {
  PARENT
  LOCATION
}

enum DeliveryDirection {
  outgoing
  incoming
}

enum DeliveryType {
  delivery
  transfer
}

enum DeliveryStatus {
  NOT_ASSIGNED
  ASSIGNED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
  VOID
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  PAYMENT_PENDING
  PENDING_CONFIRMATION
  PROCESSING
  OVERDUE
  DUE_TODAY
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

model UserConnection {
  id         String           @id @default(uuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(pending)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sender     User             @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

enum ConnectionStatus {
  pending
  accepted
  rejected
}

model BusinessConnection {
  id                  String           @id @default(uuid())
  requesterBusinessId String
  targetBusinessId    String
  status              ConnectionStatus @default(pending)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  requesterBusiness   Business         @relation("ConnectionsRequested", fields: [requesterBusinessId], references: [id], onDelete: Cascade)
  targetBusiness      Business         @relation("ConnectionsReceived", fields: [targetBusinessId], references: [id], onDelete: Cascade)

  @@unique([requesterBusinessId, targetBusinessId])
  @@index([requesterBusinessId])
  @@index([targetBusinessId])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // 'ios' | 'android'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
