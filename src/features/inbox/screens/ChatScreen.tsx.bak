            {!isOutgoing && message.sender.avatar ? <Image source={{ uri: message.sender.avatar }} style={[styles.avatarSmall, { backgroundColor: appTheme.colors.surface }]} /> : null}
            <View style={bubbleContainerStyle}>
              <View style={[bubbleStyle, { opacity: 0.6 }]}>
