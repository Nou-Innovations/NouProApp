# =============================================================================
# NouPro Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!

# =============================================================================
# Database Configuration (Supabase/PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public

# =============================================================================
# Authentication
# =============================================================================
# Generate a strong random string (at least 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
# For development: http://localhost:19006,http://localhost:3000
# For production: https://your-app-domain.com
CORS_ORIGIN=http://localhost:19006,http://localhost:3000

# =============================================================================
# Data Source
# =============================================================================
# Options: memory | prisma
# Use 'memory' for development without database
# Use 'prisma' for production with PostgreSQL
DATA_SOURCE=memory

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
HOST=0.0.0.0
