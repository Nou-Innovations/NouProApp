# =============================================================================
# NouPro Backend Environment Configuration — EXAMPLE
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control — it is gitignored.
#
# To generate a strong JWT_SECRET, run:
#   openssl rand -base64 48

# =============================================================================
# Database Configuration (Supabase/PostgreSQL)
# =============================================================================
# DATABASE_URL = pooled connection (pgbouncer, port 6543) — used by the app for queries.
# DIRECT_URL   = DIRECT/session connection (port 5432, NO pgbouncer) — used by Prisma
#                Migrate for DDL. Do NOT add "pgbouncer=true" to DIRECT_URL; migrations
#                need a non-pooled connection or they can fail / behave inconsistently.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?schema=public&sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&sslmode=require"

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET=your-secret-here-generate-with-openssl-rand-base64-48

# =============================================================================
# Email Configuration (for password reset)
# =============================================================================
# Uses nodemailer with SMTP. Works with Gmail, Outlook, Resend SMTP, etc.
# For Gmail: enable 2FA and use an App Password (myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=NouPro <noreply@noupro.app>
APP_BASE_URL=https://your-backend-url.onrender.com

# =============================================================================
# File Storage (Supabase Storage)
# =============================================================================
# Uploaded images (avatars, company/business logos, product photos) are stored
# in a Supabase Storage bucket so they PERSIST across deploys.
#
# IMPORTANT: Render's filesystem is ephemeral — without these set, uploads fall
# back to local disk (./uploads) and are WIPED on every redeploy. Always set
# these in production.
#
#   SUPABASE_URL              = https://<project-ref>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY = the "service_role" key (Dashboard → Settings → API).
#                               SECRET — backend only, bypasses RLS. Never expose to the app.
#   SUPABASE_STORAGE_BUCKET   = bucket name (must be a PUBLIC bucket). Default: uploads
#
# Setup: in the Supabase dashboard create a PUBLIC bucket named "uploads", then
# fill in the values below (and add the same vars in the Render dashboard).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGIN=http://localhost:19006,http://localhost:3000

# =============================================================================
# Data Source
# =============================================================================
# Options: memory | prisma
# Use 'memory' for development without database
# Use 'prisma' for production with PostgreSQL
DATA_SOURCE=prisma

# =============================================================================
# Error Monitoring (Sentry) — OPTIONAL
# =============================================================================
# Create a project at sentry.io, copy its DSN here. Leave blank to disable
# (no monitoring, zero overhead). When set, unhandled errors are reported.
SENTRY_DSN=

# =============================================================================
# OTP / SMS Verification (Twilio Verify) — OPTIONAL
# =============================================================================
# Required only if phone/email OTP is enabled. Leave blank to disable.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# =============================================================================
# Payments (Peach Payments) — OPTIONAL
# =============================================================================
# Required only for subscription/invoice payments. Leave blank until ready.
# These names MUST match what src/services/peachPayments.js reads.
PEACH_API_URL=https://testsecure.peachpayments.com
PEACH_ENTITY_ID=
PEACH_SECRET_TOKEN=
PEACH_MERCHANT_ID=
PEACH_RECURRING_ENTITY_ID=

# =============================================================================
# Automation (scheduled jobs / cron endpoints) — OPTIONAL
# =============================================================================
# Shared secret required to call /api/automation/* endpoints.
AUTOMATION_API_KEY=

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
