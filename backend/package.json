{
  "name": "noupro-backend",
  "version": "1.0.0",
  "description": "Mock backend server for NouPro app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "prisma:seed": "node scripts/guard-not-prod.js && node prisma/seed.js",
    "prisma:studio": "prisma studio --schema ./prisma/schema.prisma",
    "db:reset": "node scripts/guard-not-prod.js && prisma migrate reset --force --schema ./prisma/schema.prisma"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "@sentry/node": "^10.55.0",
    "@supabase/supabase-js": "^2.107.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^5.0.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "otplib": "^13.3.0",
    "pg": "^8.16.3",
    "prisma": "^6.19.1",
    "socket.io": "^4.8.3",
    "twilio": "^5.12.2",
    "uuid": "^9.0.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "api",
    "express",
    "noupro"
  ],
  "author": "NouPro Team",
  "license": "MIT"
}
