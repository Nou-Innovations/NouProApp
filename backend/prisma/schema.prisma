generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id
  name            String?
  email           String?
  avatar          String?
  phone           String?
  description     String?
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  businessMembers BusinessMember[]
  locationMembers LocationMember[]
}

model Business {
  id               String            @id
  name             String
  logoUrl          String?
  description      String?
  phone            String?
  email            String?
  subscriptionTier SubscriptionTier  @default(FREE)
  settings         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  businessMembers  BusinessMember[]
  chats            Chat[]
  deliveries       Delivery[]
  feedPosts        FeedPost[]
  invoices         Invoice[]
  locations        Location[]
  locationMembers  LocationMember[]
  locationProducts LocationProduct[]
  orders           Order[]
  products         Product[]
  stocks           Stock[]
}

model Location {
  id               String            @id
  businessId       String
  name             String
  address          String?
  phone            String?
  email            String?
  latitude         Float?
  longitude        Float?
  operatingMode    LocationMode      @default(DEPENDENT)
  isPublic         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  chats            Chat[]
  deliveries       Delivery[]
  invoices         Invoice[]
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locationMembers  LocationMember[]
  locationProducts LocationProduct[]
  ordersFulfill    Order[]           @relation("OrdersFulfilledByLocation")
  ordersSold       Order[]           @relation("OrdersSoldByLocation")
  stocks           Stock[]

  @@index([businessId])
}

model Product {
  id               String            @id
  businessId       String
  name             String
  brand            String?
  brandLogo        String?
  productPicture   String?
  price            Float?
  category         String?
  status           String?
  variants         Json?
  unit             String?
  stockQuantity    Int?
  isListed         Boolean?          @map("is_listed")
  isCreatedByUser  Boolean?
  isDisplayable    Boolean?
  isImported       Boolean?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  locationProducts LocationProduct[]
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stocks           Stock[]

  @@index([businessId])
}

model LocationProduct {
  id            String   @id
  businessId    String
  locationId    String
  productId     String
  priceOverride Float?
  taxOverride   Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([businessId])
}

model Stock {
  id         String   @id
  businessId String
  locationId String
  productId  String
  qtyOnHand  Int      @default(0)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([businessId])
}

model Order {
  id                    String         @id
  businessId            String
  soldByScope           OrderScope     @default(PARENT)
  soldByLocationId      String?
  fulfillmentLocationId String?
  customerId            String?
  customerName          String?
  customerAddress       String?
  customerPhone         String?
  items                 Json
  totalAmount           Float?
  status                OrderStatus    @default(NEW)
  paymentStatus         PaymentStatus? @default(UNPAID)
  deliveryStatus        DeliveryStatus @default(NOT_ASSIGNED)
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  
  // Status tracking fields
  statusChangedAt       DateTime       @default(now())
  statusChangedBy       String?        // userId who changed status
  statusReason          String?        // Required for PENDING/CANCELED/REJECTED
  lastActivityAt        DateTime       @default(now())
  
  // Relations
  business              Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fulfillmentLocation   Location?   @relation("OrdersFulfilledByLocation", fields: [fulfillmentLocationId], references: [id])
  soldByLocation        Location?   @relation("OrdersSoldByLocation", fields: [soldByLocationId], references: [id])
  statusHistory         OrderStatusHistory[]

  @@index([businessId])
  @@index([soldByLocationId])
  @@index([fulfillmentLocationId])
  @@index([status])
  @@index([lastActivityAt])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  from      OrderStatus
  to        OrderStatus
  reason    String?
  changedBy String?     // userId
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Invoice {
  id                 String       @id
  businessId         String
  issuedByScope      InvoiceScope @default(PARENT)
  issuedByLocationId String?
  orderId            String?
  invoiceNumber      String?
  clientName         String?
  clientEmail        String?
  amount             Float?
  taxAmount          Float?
  totalAmount        Float?
  status             InvoiceStatus? @default(DRAFT)
  type               String?
  issueDate          String?
  dueDate            String?
  items              Json
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  business           Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location           Location?    @relation(fields: [issuedByLocationId], references: [id])

  @@index([businessId])
  @@index([issuedByLocationId])
}

model Chat {
  id           String    @id
  businessId   String
  locationId   String?
  type         String?
  name         String?
  participants Json?
  lastMessage  Json?
  unreadCount  Int?
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location     Location? @relation(fields: [locationId], references: [id])
  messages     Message[]

  @@index([businessId])
  @@index([locationId])
}

model Message {
  id         String   @id
  chatId     String
  senderId   String?
  senderName String?
  content    String?
  type       String?
  timestamp  DateTime @default(now())
  meta       Json?
  status     String?
  isRead     Boolean  @default(false)
  isOutgoing Boolean  @default(false)
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

model BusinessMember {
  id         String       @id
  businessId String
  userId     String
  role       MemberRole
  status     MemberStatus @default(pending)
  createdAt  DateTime     @default(now())
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
}

model LocationMember {
  id          String       @id
  locationId  String
  businessId  String
  userId      String
  role        MemberRole
  status      MemberStatus @default(pending)
  permissions Json?
  createdAt   DateTime     @default(now())
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location    Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([locationId, userId])
  @@index([locationId])
  @@index([businessId])
}

model Delivery {
  id                       String    @id
  businessId               String
  locationId               String?
  direction                String?
  type                     String?
  clientId                 String?
  clientCompanyLogo        String?
  clientCompanyName        String?
  clientAddress            String?
  clientEmail              String?
  clientPhone              String?
  clientNotes              String?
  distributorNotes         String?
  fromLocation             String?
  toLocation               String?
  orderTime                DateTime?
  expectedDeliveryDateTime DateTime?
  itemCount                Int?
  items                    Json?
  totalAmount              Float?
  trackingNumber           String?
  deliveryStatus           DeliveryStatus @default(NOT_ASSIGNED)
  paymentStatus            PaymentStatus  @default(UNPAID)
  assignedStaffId          String?
  assignedTo               String?
  transportMode            String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  business                 Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location                 Location? @relation(fields: [locationId], references: [id])

  @@index([businessId])
  @@index([locationId])
}

model FeedPost {
  id         String    @id
  businessId String?
  type       String
  timestamp  String?
  data       Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([type])
}

// Tracks read state for derived notifications
// Since notifications are computed at fetch time, this table stores
// which notification keys have been read by each user
model NotificationRead {
  id              String   @id @default(uuid())
  userId          String
  notificationKey String   // Derived key like "join-request-{id}" or "invoice-{id}"
  readAt          DateTime @default(now())

  @@unique([userId, notificationKey])
  @@index([userId])
}

enum SubscriptionTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum LocationMode {
  DEPENDENT
  INDEPENDENT
}

enum MemberRole {
  super_admin
  admin
  staff
}

enum MemberStatus {
  pending
  accepted
  rejected
  locked
}

enum OrderStatus {
  NEW
  ACCEPTED
  ONGOING
  PENDING
  IN_REVIEW
  DONE
  CANCELED
  REJECTED
}

enum OrderScope {
  PARENT
  LOCATION
}

enum InvoiceScope {
  PARENT
  LOCATION
}

// Payment status for orders
enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  PAYMENT_PENDING
  PENDING_CONFIRMATION
  PROCESSING
  OVERDUE
  DUE_TODAY
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

// Invoice status
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
  VOID
  REFUNDED
}

// Delivery status for order fulfillment tracking
enum DeliveryStatus {
  NOT_ASSIGNED
  ASSIGNED
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELED
}
