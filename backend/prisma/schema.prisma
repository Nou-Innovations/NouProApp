// ── Task Enums ──

enum TaskType {
  GENERAL
  DELIVERY
  ORDER
  INVOICE
  INVENTORY
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  URGENT
}

// ── Task Model ──

model Task {
  id               String       @id
  businessId       String
  locationId       String?
  title            String
  description      String?      @db.Text
  type             TaskType     @default(GENERAL)
  status           TaskStatus   @default(TODO)
  priority         TaskPriority @default(NORMAL)
  assignedToUserId String?
  assignedByUserId String?
  createdByUserId  String
  dueDate          DateTime?
  completedAt      DateTime?
  linkedOrderId    String?
  linkedDeliveryId String?
  linkedInvoiceId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  business         Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location         Location?    @relation(fields: [locationId], references: [id])

  @@index([businessId, status])
  @@index([businessId, assignedToUserId])
  @@index([assignedToUserId])
  @@index([linkedOrderId])
  @@index([linkedDeliveryId])
  @@index([linkedInvoiceId])
}

// ── Customer (sell-side CRM directory) ──
// Mirrors Supplier (buy-side): a record a business keeps about who it sells to.
// Supports both a linked NouPro business (customerBusinessId) AND a standalone
// external contact (name/email/phone only, no link).

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

model Customer {
  id                 String         @id
  businessId         String
  customerBusinessId String?
  name               String
  contactName        String?
  email              String?
  phone              String?
  address            String?
  notes              String?
  status             CustomerStatus @default(ACTIVE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  business         Business  @relation("BusinessCustomers", fields: [businessId], references: [id], onDelete: Cascade)
  customerBusiness Business? @relation("CustomerLinkedBusiness", fields: [customerBusinessId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, status])
  @@index([customerBusinessId])
}

// ── Discount (seller promotions + coupon codes) ──
// Applied server-side in priceResolution AFTER the price-list step. `code` null =
// automatic promotion (auto-applies to matching products in its window); `code` set =
// coupon entered at checkout. Scope targets (productIds/categories) are JSON string
// arrays (matching the Product.variants Json convention; the schema has no scalar lists).

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum DiscountScope {
  ALL
  PRODUCTS
  CATEGORY
}

model Discount {
  id             String        @id
  businessId     String
  name           String
  description    String?
  type           DiscountType  @default(PERCENTAGE)
  value          Float
  scope          DiscountScope @default(ALL)
  productIds     Json?
  categories     Json?
  code           String?
  minOrderAmount Float?
  startDate      DateTime?
  endDate        DateTime?
  maxUses        Int?
  usedCount      Int           @default(0)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  business       Business      @relation("BusinessDiscounts", fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, isActive])
}

// ── Business Target (monthly budget goals for the Variance report) ──
// One row per business per month ('YYYY-MM'). Powers the Budget-vs-Actual section.

model BusinessTarget {
  id            String   @id            // 'tgt-' + uuidv4().slice(0,8)
  businessId    String
  period        String                   // month key 'YYYY-MM'
  revenueTarget Float?
  ordersTarget  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business      Business @relation("BusinessTargets", fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, period])
  @@index([businessId])
}

// ── Procurement Models ──

model Supplier {
  id                 String         @id
  businessId         String
  supplierBusinessId String?
  name               String
  contactName        String?
  email              String?
  phone              String?
  address            String?
  paymentTerms       String?
  leadTimeDays       Int?
  creditLimit        Float?
  rating             Float?
  status             SupplierStatus @default(ACTIVE)
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierBusiness Business?         @relation("SupplierBusiness", fields: [supplierBusinessId], references: [id], onDelete: SetNull)
  products         SupplierProduct[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]

  @@unique([businessId, supplierBusinessId])
  @@index([businessId])
  @@index([supplierBusinessId])
}

model SupplierProduct {
  id            String   @id @default(uuid())
  supplierId    String
  productId     String
  supplierPrice Float
  minOrderQty   Int?
  bulkPrice     Float?
  bulkMinQty    Int?
  supplierSKU   String?
  leadTimeDays  Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@index([productId])
}

model PurchaseRequest {
  id              String                  @id
  businessId      String
  locationId      String?
  supplierId      String?
  requestedBy     String
  priority        PurchaseRequestPriority @default(NORMAL)
  status          PurchaseRequestStatus   @default(DRAFT)
  items           Json
  totalAmount     Float?
  notes           String?
  requiredByDate  DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  purchaseOrderId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([status])
}

model PurchaseOrder {
  id                   String              @id
  businessId           String
  supplierId           String
  purchaseRequestId    String?
  locationId           String?
  poNumber             String?
  items                Json
  totalAmount          Float?
  status               PurchaseOrderStatus @default(DRAFT)
  paymentStatus        PaymentStatus?      @default(UNPAID)
  paymentTerms         String?
  expectedDeliveryDate DateTime?
  notes                String?
  sentAt               DateTime?
  createdBy            String
  approvedBy           String?
  statusChangedAt      DateTime?
  statusChangedBy      String?
  statusReason         String?
  lastActivityAt       DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  business      Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier      Supplier                     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  statusHistory PurchaseOrderStatusHistory[]
  goodsReceipts GoodsReceipt[]

  @@unique([businessId, poNumber])
  @@index([businessId])
  @@index([businessId, paymentStatus])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderStatusHistory {
  id              String              @id @default(uuid())
  purchaseOrderId String
  from            PurchaseOrderStatus
  to              PurchaseOrderStatus
  reason          String?
  changedBy       String?
  createdAt       DateTime            @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String             @id
  businessId      String
  purchaseOrderId String
  locationId      String?
  receivedBy      String
  items           Json
  status          GoodsReceiptStatus @default(PENDING)
  receivedAt      DateTime?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([purchaseOrderId])
}

model UserConnection {
  id         String           @id @default(uuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(pending)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sender     User             @relation("ConnectionSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("ConnectionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

enum ConnectionStatus {
  pending
  accepted
  rejected
}

// A one-directional block: blocker has blocked blocked. Enforcement treats a block in
// EITHER direction as mutual (no connect/chat either way) — see blockRepo.isBlocked.
model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model BusinessConnection {
  id                  String           @id @default(uuid())
  requesterBusinessId String
  targetBusinessId    String
  status              ConnectionStatus @default(pending)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  requesterBusiness   Business         @relation("ConnectionsRequested", fields: [requesterBusinessId], references: [id], onDelete: Cascade)
  targetBusiness      Business         @relation("ConnectionsReceived", fields: [targetBusinessId], references: [id], onDelete: Cascade)

  @@unique([requesterBusinessId, targetBusinessId])
  @@index([requesterBusinessId])
  @@index([targetBusinessId])
}

// ── Phase 2: Company Pages + Payments ──

model BusinessFollow {
  id         String   @id @default(uuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

model Payment {
  id                 String                  @id @default(uuid())
  businessId         String
  invoiceId          String?
  type               PaymentType
  amount             Float
  currency           String                  @default("MUR")
  status             PaymentProcessingStatus @default(PENDING)
  peachCheckoutId    String?                 @unique
  peachTransactionId String?                 @unique
  description        String?
  metadata           Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  business           Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice            Invoice?                @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, type])
  @@index([invoiceId])
  @@index([peachCheckoutId])
}

enum PaymentType {
  SUBSCRIPTION
  INVOICE_PAYMENT
}

enum PaymentProcessingStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
}

// ── Opportunities (B2B requests / "looking for") ──

enum OpportunityType {
  buying
  selling
  partnership
  service
  hiring
  other
}

enum OpportunityStatus {
  open
  closed
  fulfilled
}

model Opportunity {
  id              String                @id @default(uuid())
  businessId      String
  title           String
  description     String?               @db.Text
  type            OpportunityType       @default(buying)
  category        String?
  budgetMin       Float?
  budgetMax       Float?
  currency        String                @default("MUR")
  locationText    String?
  status          OpportunityStatus     @default(open)
  expiresAt       DateTime?
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  business        Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  responses       OpportunityResponse[]

  @@index([businessId])
  @@index([status])
  @@index([type, status])
  @@index([category])
}

model OpportunityResponse {
  id                  String      @id @default(uuid())
  opportunityId       String
  responderBusinessId String
  message             String?     @db.Text
  createdByUserId     String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  opportunity         Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  responderBusiness   Business    @relation("OpportunityResponder", fields: [responderBusinessId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, responderBusinessId])
  @@index([opportunityId])
  @@index([responderBusinessId])
}

// ── Events (B2B networking / workshops / conferences) ──

enum EventType {
  workshop
  coffee_connect
  conference
  panel
  webinar
  networking
  other
}

enum EventStatus {
  scheduled
  cancelled
  completed
}

enum RSVPStatus {
  going
  interested
  cancelled
}

model Event {
  id              String      @id @default(uuid())
  businessId      String
  title           String
  description     String?     @db.Text
  type            EventType   @default(networking)
  startAt         DateTime
  endAt           DateTime?
  locationText    String?
  isOnline        Boolean     @default(false)
  onlineUrl       String?
  coverImageUrl   String?
  capacity        Int?
  status          EventStatus @default(scheduled)
  createdByUserId String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rsvps           EventRSVP[]

  @@index([businessId])
  @@index([status, startAt])
  @@index([startAt])
}

model EventRSVP {
  id         String     @id @default(uuid())
  eventId    String
  businessId String
  userId     String
  status     RSVPStatus @default(going)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, businessId])
  @@index([eventId])
  @@index([businessId])
}

// Community feedback board — global (scoped by user, not company).
model Suggestion {
  id         String           @id @default(uuid())
  userId     String
  categoryId String
  text       String           @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation("SuggestionAuthor", fields: [userId], references: [id], onDelete: Cascade)
  votes      SuggestionVote[]

  @@index([categoryId])
  @@index([createdAt])
  @@index([userId])
}

model SuggestionVote {
  id           String     @id @default(uuid())
  suggestionId String
  userId       String
  createdAt    DateTime   @default(now())
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User       @relation("SuggestionVoter", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId]) // double-vote guard
  @@index([userId])
  @@index([suggestionId])
}

// User-submitted content reports (products today; targetType keeps it generic
// for businesses etc. later). Polymorphic targetId, so no FK relation.
model Report {
  id                   String   @id @default(uuid())
  targetType           String // 'product' | 'business'
  targetId             String
  reason               String // 'inappropriate' | 'counterfeit' | 'wrong_info' | 'spam' | 'other'
  details              String?
  reportedByUserId     String?
  reportedByBusinessId String?
  status               String   @default("open") // 'open' | 'reviewed' | 'dismissed'
  createdAt            DateTime @default(now())

  @@index([targetType, targetId])
  @@index([status])
}
