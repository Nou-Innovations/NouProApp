enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CONVERTED
}

enum PurchaseRequestPriority {
  LOW
  NORMAL
  URGENT
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
