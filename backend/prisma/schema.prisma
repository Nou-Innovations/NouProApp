generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String           @id
  name                 String?
  email                String?          @unique
  avatar               String?
  phone                String?          @unique
  passwordHash         String?
  twoFactorSecret      String?
  twoFactorEnabled     Boolean          @default(false)
  twoFactorBackupCodes String?
  tokenVersion         Int              @default(0)
  jobTitle             String?
  description          String?
  address              String?
  language             String?          @default("EN")
  privacySettings      Json?
  lastLoginAt          DateTime?
  headline             String?
  bio                  String?          @db.Text
  industry             String?
  coverPhoto           String?
  profileSlug          String?          @unique
  deletedAt            DateTime? // set when the account is erased/anonymized (GDPR). NULL = active.
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  businessMembers      BusinessMember[]
  locationMembers      LocationMember[]
  deliveryAssignments  DeliveryStaff[]  @relation("DeliveryStaffUser")
  roleRequests         RoleRequest[]    @relation("RoleRequestUser")
  sentConnections      UserConnection[] @relation("ConnectionSender")
  receivedConnections  UserConnection[] @relation("ConnectionReceiver")
  blocksInitiated      Block[]          @relation("Blocker")
  blocksReceived       Block[]          @relation("Blocked")
  workExperiences      WorkExperience[]
  education            Education[]
  certifications       Certification[]
  userSkills           UserSkill[]
  businessFollows      BusinessFollow[]
  suggestions          Suggestion[]     @relation("SuggestionAuthor")
  suggestionVotes      SuggestionVote[] @relation("SuggestionVoter")
}

model Business {
  id                      String                @id
  name                    String
  logoUrl                 String?
  bannerUrl               String?
  description             String?
  industry                String?
  category                String?
  phone                   String?
  email                   String?
  address                 String?
  website                 String?
  isPublished             Boolean               @default(false)
  isVerified              Boolean               @default(false)
  size                    String?
  foundedYear             Int?
  subscriptionTier        SubscriptionTier      @default(FREE)
  billingPeriod           BillingPeriod         @default(MONTHLY)
  currentPeriodEnd        DateTime?
  peachCustomerId         String?               @unique
  peachCardRegistrationId String?
  settings                Json?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  businessMembers         BusinessMember[]
  chats                   Chat[]
  deliveries              Delivery[]
  feedPosts               FeedPost[]
  invoices                Invoice[]
  locations               Location[]
  locationMembers         LocationMember[]
  locationProducts        LocationProduct[]
  orders                  Order[]
  products                Product[]
  stocks                  Stock[]
  brands                  Brand[]
  collections             Collection[]
  transports              Transport[]
  roleRequests            RoleRequest[]
  connectionsSent         BusinessConnection[]  @relation("ConnectionsRequested")
  connectionsReceived     BusinessConnection[]  @relation("ConnectionsReceived")
  suppliers               Supplier[]
  supplierOf              Supplier[]            @relation("SupplierBusiness")
  purchaseRequests        PurchaseRequest[]
  purchaseOrders          PurchaseOrder[]
  goodsReceipts           GoodsReceipt[]
  tasks                   Task[]
  followers               BusinessFollow[]
  payments                Payment[]
  opportunities           Opportunity[]
  opportunityResponses    OpportunityResponse[] @relation("OpportunityResponder")
  events                  Event[]
  issues                  Issue[]
  returns                 Return[]
  routes                  Route[]
  recurringSchedules      RecurringSchedule[]
  stockMovements          StockMovement[]
  transfers               Transfer[]
  priceLists              PriceList[]
  customers               Customer[]            @relation("BusinessCustomers")
  customerLinks           Customer[]            @relation("CustomerLinkedBusiness")
  discounts               Discount[]            @relation("BusinessDiscounts")
  targets                 BusinessTarget[]      @relation("BusinessTargets")
}

model Location {
  id               String            @id
  businessId       String
  name             String
  address          String?
  phone            String?
  email            String?
  locationType     String?
  latitude         Float?
  longitude        Float?
  operatingMode    LocationMode      @default(DEPENDENT)
  isPublic         Boolean           @default(false)
  isPrimary        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  chats            Chat[]
  deliveries       Delivery[]
  invoices         Invoice[]
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locationMembers  LocationMember[]
  locationProducts LocationProduct[]
  ordersFulfill    Order[]           @relation("OrdersFulfilledByLocation")
  ordersSold       Order[]           @relation("OrdersSoldByLocation")
  stocks           Stock[]
  tasks            Task[]

  @@index([businessId])
}

// ── Professional Profile Models ──

model WorkExperience {
  id               String    @id @default(uuid())
  userId           String
  companyName      String
  companyLogo      String?
  position         String
  description      String?   @db.Text
  industry         String?
  location         String?
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean   @default(false)
  linkedBusinessId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Education {
  id           String    @id @default(uuid())
  userId       String
  institution  String
  degree       String?
  fieldOfStudy String?
  description  String?   @db.Text
  startDate    DateTime?
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Certification {
  id                  String    @id @default(uuid())
  userId              String
  name                String
  issuingOrganization String
  issueDate           DateTime?
  expirationDate      DateTime?
  credentialId        String?
  credentialUrl       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Skill {
  id         String      @id @default(uuid())
  name       String      @unique
  category   String?
  createdAt  DateTime    @default(now())
  userSkills UserSkill[]
}

model UserSkill {
  id           String   @id @default(uuid())
  userId       String
  skillId      String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill        Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
}

model Brand {
  id          String    @id
  businessId  String
  name        String
  logoUrl     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId])
}

// ── Collections (internal product groupings — quota-gated by maxCollections) ──
//
// A Collection belongs to a business and groups its own products into a named set
// (e.g. "Summer 2026"). A product can belong to many collections via CollectionProduct.
// Internal only — not shown to buyers / not published to any public storefront.

model Collection {
  id          String              @id
  businessId  String
  name        String
  description String?
  coverImage  String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    CollectionProduct[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([businessId, isActive])
}

model CollectionProduct {
  id           String     @id
  collectionId String
  productId    String
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
}

// ── Price Lists (customer-specific pricing — gated by canUseBusinessSpecificPricing) ──
//
// A PriceList belongs to a SELLER business. It can carry a list-wide discountPercent
// AND per-product fixed-price overrides (PriceListItem). It is applied to customer
// businesses either via PriceListAssignment (auto) or manually at order/invoice time.
// Resolution precedence: per-product fixed override > list discountPercent > base price.

model PriceList {
  id              String                @id
  businessId      String // SELLER business that owns this list
  name            String
  description     String?
  discountPercent Float? // list-wide % off base price (0–100). Null = no list discount.
  currency        String? // optional; if set, only applied to products in this currency
  isActive        Boolean               @default(true)
  isDefault       Boolean               @default(false) // fallback list applied when no specific assignment
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  business        Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items           PriceListItem[]
  assignments     PriceListAssignment[]

  @@index([businessId])
  @@index([businessId, isActive])
}

model PriceListItem {
  id                  String    @id
  priceListId         String
  productId           String
  fixedPrice          Float? // explicit per-unit price override (wins over list discountPercent)
  fixedPricePerCarton Float? // explicit carton price override (mirrors Product.pricePerCarton)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  priceList           PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@index([priceListId])
  @@index([productId])
}

model PriceListAssignment {
  id               String    @id
  priceListId      String
  sellerBusinessId String // denormalized for the unique constraint + fast lookup
  buyerBusinessId  String // the CUSTOMER business this list auto-applies to
  createdAt        DateTime  @default(now())
  priceList        PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([sellerBusinessId, buyerBusinessId]) // a customer maps to at most one auto-applied list per seller; also serves lookups
  @@index([priceListId])
}

model Transport {
  id              String   @id
  businessId      String
  name            String
  vehicleType     String
  licensePlate    String?
  capacity        String?
  status          String   @default("available")
  assignedStaffId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([assignedStaffId])
}

model Product {
  id                  String            @id
  businessId          String
  name                String
  brand               String?
  brandLogo           String?
  brandId             String?
  sourceProductId     String? // when set, this is a client's "carried" copy of another business's product
  productPicture      String?
  price               Float?
  category            String?
  status              String?
  variants            Json?
  unit                String?
  isListed            Boolean?          @map("is_listed")
  isCreatedByUser     Boolean?
  isDisplayable       Boolean?
  isImported          Boolean?
  description         String?
  costPrice           Float?
  salePrice           Float?
  sku                 String?
  barcode             String?
  taxRate             Float?
  supplier            String?
  hasCarton           Boolean?          @default(false)
  unitsPerCarton      Int?
  pricePerCarton      Float?
  hasRetailPriceLimit Boolean?          @default(false)
  retailPriceLimit    Float?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  locationProducts    LocationProduct[]
  business            Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  brandRef            Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  stocks              Stock[]
  supplierProducts    SupplierProduct[]
  priceListItems      PriceListItem[]
  collectionProducts  CollectionProduct[]

  @@index([businessId])
  @@index([businessId, category])
  @@index([businessId, isListed])
  @@index([businessId, sourceProductId])
  @@index([brandId])
}

model LocationProduct {
  id            String   @id
  businessId    String
  locationId    String
  productId     String
  priceOverride Float?
  taxOverride   Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([businessId])
}

model Stock {
  id           String   @id
  businessId   String
  locationId   String
  productId    String
  qtyOnHand    Int      @default(0)
  qtyReserved  Int      @default(0)
  qtyInTransit Int      @default(0)
  reorderLevel Int?
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([businessId])
  @@index([productId])
}

model Order {
  id                    String               @id
  businessId            String
  soldByScope           OrderScope           @default(PARENT)
  soldByLocationId      String?
  fulfillmentLocationId String?
  customerId            String?
  customerName          String?
  customerAddress       String?
  customerPhone         String?
  buyerBusinessId       String?
  buyerBusinessName     String?
  createdBy             String?
  items                 Json
  totalAmount           Float?
  status                OrderStatus          @default(NEW)
  paymentStatus         PaymentStatus?       @default(UNPAID)
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  deliveryStatus        DeliveryStatus?      @default(Draft)
  statusChangedAt       DateTime?
  statusChangedBy       String?
  statusReason          String?
  lastActivityAt        DateTime?
  business              Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fulfillmentLocation   Location?            @relation("OrdersFulfilledByLocation", fields: [fulfillmentLocationId], references: [id], onDelete: SetNull)
  soldByLocation        Location?            @relation("OrdersSoldByLocation", fields: [soldByLocationId], references: [id], onDelete: SetNull)
  statusHistory         OrderStatusHistory[]
  deliveries            Delivery[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([soldByLocationId])
  @@index([fulfillmentLocationId])
  @@index([buyerBusinessId])
  @@index([customerId])
  @@index([createdBy])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  from      OrderStatus
  to        OrderStatus
  reason    String?
  changedBy String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Invoice {
  id                 String         @id
  businessId         String
  issuedByScope      InvoiceScope   @default(PARENT)
  issuedByLocationId String?
  orderId            String?
  clientBusinessId   String?
  invoiceNumber      String?
  clientName         String?
  clientEmail        String?
  clientPhone        String?
  clientAddress      String?
  customerId         String?
  amount             Float?
  taxAmount          Float?
  totalAmount        Float?
  paidAmount         Float?         @default(0)
  discount           Float?         @default(0)
  shipping           Float?         @default(0)
  currency           String?        @default("EUR")
  type               String?
  issueDate          DateTime?
  dueDate            DateTime?
  items              Json
  notes              String?
  terms              String?
  referenceNumber    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  status             InvoiceStatus? @default(DRAFT)
  business           Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location           Location?      @relation(fields: [issuedByLocationId], references: [id], onDelete: SetNull)
  payments           Payment[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([businessId, status])
  @@index([issuedByLocationId])
  @@index([status])
  @@index([createdAt])
  @@index([orderId])
  @@index([clientBusinessId])
  @@index([customerId])
}

model Chat {
  id               String            @id
  companyId        String?           @map("businessId")
  locationId       String?
  type             String?
  name             String?
  participants     Json?
  lastMessage      Json?
  unreadCount      Int               @default(0)
  avatar           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  business         Business?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location         Location?         @relation(fields: [locationId], references: [id])
  messages         Message[]
  chatParticipants ChatParticipant[]
  readReceipts     ReadReceipt[]

  @@index([companyId])
  @@index([locationId])
}

model Message {
  id           String        @id
  chatId       String
  senderId     String?
  senderName   String?
  content      String?
  type         String?
  timestamp    DateTime      @default(now())
  meta         Json?
  status       String?
  isRead       Boolean       @default(false)
  isOutgoing   Boolean       @default(false)
  chat         Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  readReceipts ReadReceipt[]

  @@index([chatId])
  @@index([chatId, timestamp])
  @@index([senderId])
}

model ChatParticipant {
  id          String   @id @default(uuid())
  chatId      String
  userId      String
  joinedAt    DateTime @default(now())
  unreadCount Int      @default(0)
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
  @@index([chatId])
}

model ReadReceipt {
  id        String   @id @default(uuid())
  chatId    String
  userId    String
  messageId String
  readAt    DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
  @@index([messageId])
}

model BusinessMember {
  id         String       @id
  businessId String
  userId     String
  role       MemberRole
  status     MemberStatus @default(pending)
  createdAt  DateTime     @default(now())
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
}

model LocationMember {
  id          String       @id
  locationId  String
  businessId  String
  userId      String
  role        MemberRole
  status      MemberStatus @default(pending)
  permissions Json?
  createdAt   DateTime     @default(now())
  business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location    Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([locationId, userId])
  @@index([locationId])
  @@index([businessId])
}

model Delivery {
  id                       String                  @id
  businessId               String
  locationId               String?
  direction                DeliveryDirection?
  type                     DeliveryType?
  clientId                 String?
  clientCompanyLogo        String?
  clientCompanyName        String?
  clientAddress            String?
  clientEmail              String?
  clientPhone              String?
  clientNotes              String?
  distributorName          String?
  distributorNotes         String?
  fromLocation             String?
  toLocation               String?
  fromLocationId           String?
  toLocationId             String?
  orderTime                DateTime?
  expectedDeliveryDateTime DateTime?
  itemCount                Int?
  items                    Json?
  totalAmount              Float?
  trackingNumber           String?
  assignedStaffId          String?
  assignedTo               String?
  transportMode            String?
  orderId                  String?
  podPhotoUrl              String?
  podSignatureUrl          String?
  deliveredAt              DateTime?
  deliveredBy              String?
  stockAppliedAt           DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  deliveryStatus           DeliveryStatus?         @default(Draft)
  paymentStatus            PaymentStatus?          @default(UNPAID)
  business                 Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location                 Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  order                    Order?                  @relation(fields: [orderId], references: [id])
  staffAssignments         DeliveryStaff[]
  statusHistory            DeliveryStatusHistory[]

  @@index([businessId])
  @@index([businessId, deliveryStatus])
  @@index([businessId, paymentStatus])
  @@index([businessId, createdAt])
  @@index([locationId])
  @@index([orderId])
  @@index([assignedStaffId])
  @@index([clientId])
}

model DeliveryStaff {
  id         String            @id @default(uuid())
  deliveryId String
  userId     String
  role       DeliveryStaffRole @default(driver)
  assignedBy String?
  assignedAt DateTime          @default(now())
  delivery   Delivery          @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  user       User              @relation("DeliveryStaffUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deliveryId, userId])
  @@index([deliveryId])
  @@index([userId])
}

model DeliveryStatusHistory {
  id         String          @id @default(uuid())
  deliveryId String
  from       DeliveryStatus?
  to         DeliveryStatus
  reason     String?
  changedBy  String?
  createdAt  DateTime        @default(now())
  delivery   Delivery        @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}

// ---------------------------------------------------------------------------
// Logistics v2 — additive models (Phase 1). No behavior change until later phases.
// ---------------------------------------------------------------------------

model Issue {
  id         String      @id @default(uuid())
  businessId String
  entityType String // 'delivery' | 'transfer' | 'route'
  entityId   String
  type       String // 'damaged' | 'missing' | 'wrong_qty' | 'customer_unavailable' | 'wrong_address' | 'vehicle' | 'late' | 'payment' | 'other'
  priority   String      @default("normal") // 'low' | 'normal' | 'high' | 'urgent'
  status     IssueStatus @default(open)
  photoUrl   String?
  note       String?
  reportedBy String?
  assignedTo String?
  resolution String?
  resolvedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, status])
  @@index([entityType, entityId])
}

model Return {
  id             String       @id @default(uuid())
  businessId     String
  orderId        String?
  customerId     String?
  customerName   String?
  locationId     String? // restock destination
  status         ReturnStatus @default(Requested)
  reason         String?
  items          Json? // [{productId, name, quantity, condition:'resellable'|'damaged', disposition:'restock'|'writeoff'}]
  creditNoteId   String? // -> Invoice
  stockAppliedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, status])
  @@index([orderId])
}

model Route {
  id          String      @id @default(uuid())
  businessId  String
  name        String?
  date        DateTime?
  driverId    String?
  transportId String?
  status      RouteStatus @default(Planned)
  stops       Json? // [{seq, type:'delivery'|'transfer', refId, address, lat, lng, status, eta}]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, status])
  @@index([driverId])
}

model RecurringSchedule {
  id             String    @id @default(uuid())
  businessId     String
  kind           String // 'delivery' | 'transfer'
  frequency      String // 'daily' | 'weekly' | 'biweekly' | 'monthly'
  daysOfWeek     Json? // e.g. [1,3,5]
  template       Json // delivery/transfer payload template
  fromLocationId String?
  toLocationId   String?
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([active, nextRunAt])
}

model StockMovement {
  id         String   @id @default(uuid())
  businessId String
  locationId String
  productId  String
  bucket     String // 'onHand' | 'reserved' | 'inTransit'
  delta      Int
  reason     String // 'order_reserve' | 'order_release' | 'delivery_dispatch' | 'delivery_deliver' | 'transfer_reserve' | 'transfer_dispatch' | 'transfer_receive' | 'goods_receipt' | 'return_restock' | 'manual_adjust'
  refType    String? // 'order' | 'delivery' | 'transfer' | 'po' | 'return' | 'manual'
  refId      String?
  phase      String? // idempotency discriminator
  createdBy  String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([refType, refId, phase, productId, bucket])
  @@index([businessId, locationId, productId])
  @@index([refType, refId])
}

enum IssueStatus {
  open
  investigating
  resolved
}

enum ReturnStatus {
  Requested
  Scheduled
  PickedUp
  Received
  Completed
  Rejected
}

enum RouteStatus {
  Planned
  Active
  Completed
  Canceled
}

// ---------------------------------------------------------------------------
// Logistics v2 — Phase 5: dedicated Transfer entity (internal stock movement
// with its own approval lifecycle). Built additively; the cutover from the old
// "Delivery row with type=transfer" model happens in P9.
// ---------------------------------------------------------------------------

model Transfer {
  id                  String                  @id @default(uuid())
  businessId          String
  fromLocationId      String?
  toLocationId        String?
  fromLocationName    String?
  toLocationName      String?
  status              TransferStatus          @default(Requested)
  requestedBy         String?
  approvedBy          String?
  rejectedReason      String?
  items               Json?
  itemCount           Int?
  totalAmount         Float?
  assignedStaffId     String?
  transportId         String?
  trackingNumber      String?
  notes               String?
  priority            String                  @default("normal")
  orderTime           DateTime?
  expectedAt          DateTime?
  dispatchedAt        DateTime?
  receivedAt          DateTime?
  stockAppliedAt      DateTime?
  recurringScheduleId String?
  legacyDeliveryId    String? // set when migrated from an old type=transfer Delivery row
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  business            Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  statusHistory       TransferStatusHistory[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([fromLocationId])
  @@index([toLocationId])
}

model TransferStatusHistory {
  id         String          @id @default(uuid())
  transferId String
  from       TransferStatus?
  to         TransferStatus
  reason     String?
  changedBy  String?
  createdAt  DateTime        @default(now())
  transfer   Transfer        @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}

enum TransferStatus {
  Requested
  Approved
  Preparing
  InTransit
  Received
  Completed
  Rejected
  Canceled
}

model RoleRequest {
  id               String            @id @default(uuid())
  businessId       String
  userId           String
  requestedRole    String            @default("admin")
  currentRole      String            @default("staff")
  status           RoleRequestStatus @default(PENDING)
  message          String?
  rejectionReason  String?
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedByName   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user             User              @relation("RoleRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
  @@index([businessId, userId, status])
}

model FeedPost {
  id         String    @id
  businessId String?
  type       String
  timestamp  String?
  data       Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([type])
}

model NotificationRead {
  id              String   @id
  userId          String
  notificationKey String
  readAt          DateTime @default(now())

  @@unique([userId, notificationKey])
  @@index([userId])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String
  platform  String
  deviceId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
}

model NotificationPreference {
  id         String   @id @default(uuid())
  userId     String   @unique
  messages   Boolean  @default(true)
  deliveries Boolean  @default(true)
  invoices   Boolean  @default(true)
  orders     Boolean  @default(true)
  team       Boolean  @default(true)
  system     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

