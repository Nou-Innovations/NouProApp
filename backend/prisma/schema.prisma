  PARTIALLY_PAID
  PAID
  PAYMENT_PENDING
  PENDING_CONFIRMATION
  PROCESSING
  OVERDUE
  DUE_TODAY
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

