############################################
# OS / Editor
############################################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

.vscode/
.idea/
*.iml
*.swp
*.swo
*.log

############################################
# Node / JS / TS
############################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

dist/
build/
out/
.tmp/
.temp/
.cache/

*.tsbuildinfo

############################################
# Environment files (CRITICAL)
############################################
.env
.env.*
!.env.example
!.env.sample
!.env.template

# If you use dotenv specifically
.env.local
.env.development
.env.production
.env.test

############################################
# Secrets / Keys / Certificates (CRITICAL)
############################################
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.mobileprovision

# Generic key folders
keys/
secrets/
certs/
certificates/

############################################
# Expo / React Native
############################################
.expo/
.expo-shared/
web-build/

# Expo EAS / local builds
.eas/
*.apk
*.aab
*.ipa

# Metro / React Native caches
.metro-cache/
react-native-packager-cache/
npm-packages-offline-cache/
*.hbc

############################################
# iOS (React Native / Expo prebuild)
############################################
ios/Pods/
ios/build/
ios/DerivedData/
ios/*.xcworkspace
ios/*.xcodeproj/project.xcworkspace/

# Xcode user data
ios/**/*.pbxuser
ios/**/*.mode1v3
ios/**/*.mode2v3
ios/**/*.perspectivev3
ios/**/*.xcuserstate
ios/**/xcuserdata/

############################################
# Android (React Native / Expo prebuild)
############################################
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/captures/
android/.idea/

############################################
# Prisma
############################################
# Prisma generates client code in node_modules by default (safe),
# but if you output elsewhere, ignore it:
prisma/generated/
prisma/client/

############################################
# Backend uploads / local storage (if any)
############################################
uploads/
storage/
tmp/
temp/

############################################
# Testing / Coverage
############################################
coverage/
.nyc_output/
.junit/
test-results/

############################################
# Logs
############################################
logs/
*.log

############################################
# Misc
############################################
*.zip
*.tar
*.gz
*.rar

############################################
# Optional: Cursor / AI tooling (keep private)
############################################
.cursor/
.cursor/*
!.cursor/extensions.json
!.cursor/settings.json
!.cursor/rules
!.cursor/rules/*
__MACOSX/

# Claude Code worktrees (local session copies — never commit)
.claude/worktrees/
